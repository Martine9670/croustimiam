<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Crousti Miam" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Bootstrap CSS via CDN (chargé en premier) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" 
          rel="stylesheet" 
          integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" 
          crossorigin="anonymous">

    <!-- Ton CSS personnalisé (chargé après Bootstrap pour pouvoir surcharger les styles si besoin) -->
      <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
      <%= javascript_importmap_tags %>
      <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
  </head>

  <body>
    <header class="p-4 mb-4">
      <nav class="container-fluid d-flex justify-content-between align-items-center">            
        <h2 class="title">🍽️ CroustiMiam 🍽️ </h2>
        <div>
<div class="d-flex align-items-center gap-2 p-2">
  <% if user_signed_in? %>
    <span class="text me-3 header-text">
      Bonjour et bienvenue ! Ici vous trouverez des recettes simples et savoureuses.
    </span>

  <div class="d-flex gap-2 flex-wrap">
      <%= link_to "Accueil", root_path, class: "btn btn-primary flex-fill" %>
      <%= link_to "Mon profil", profile_path, class: "btn btn-info flex-fill" %>

      <% if admin? %>
        <%= link_to "Dashboard Admin", admin_dashboard_path, class: "btn btn-warning flex-fill" %>
      <% end %>

      <%= button_to "Déconnexion", destroy_user_session_path, method: :delete, class: "btn btn-danger flex-fill" %>
    </div>
  <% else %>

    <div class="d-flex gap-2 flex-wrap">
      <%= link_to "Accueil", root_path, class: "btn btn-primary flex-fill" %>
      <%= link_to "Créer un compte", new_user_registration_path, class: "btn btn-info flex-fill" %>
      <%= button_to "Connexion", new_user_session_path, class: "btn btn-success flex-fill" %>
    </div>
  <% end %>
</div>
      </nav>
    </header>
  <main class="container flex-grow-1">
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == "notice" ? "success" : "danger" %> alert-dismissible fade show" role="alert">
          <%= message %>
        </div>
      <% end %>      
    <%= yield %>
    </main>

    <footer class="bg-primary text-light py-1 mt-auto">
      <div class="container text-center">
        <small>© 2025 - CroustiMiam - Tous droits réservés.</small><br>
        <small>Contact : <a href="mailto:contact@croustimiam.com" class="text-light text-decoration-underline">contact@croustimiam.com</a></small>
      </div>
    </footer>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        setTimeout(() => {
          document.querySelectorAll('.alert').forEach(el => {
            el.classList.remove('show');
            setTimeout(() => el.remove(), 300); // attends la fin de l'animation
          });
        }, 5000); // 5 secondes
      });
    </script>  
  </body>
</html>
